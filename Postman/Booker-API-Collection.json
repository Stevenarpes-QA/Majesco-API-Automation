    {
      "name": "Get Booking Delete",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. El éxito aquí es que el recurso NO EXISTA",
              "pm.test(\"Status 404 - Confirmado: El registro ya no existe en Majesco\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "// 2. Validar el mensaje de error del servidor",
              "pm.test(\"Mensaje de respuesta es 'Not Found'\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"Not Found\");",
              "});",
              "",
              "// 3. Log de Consola para tu reporte",
              "if (pm.response.code === 404) {",
              "    console.log(\"✅ Verificación Exitosa: El ID \" + pm.environment.get(\"last_booking_id\") + \" fue purgado de la base de datos.\");",
              "} else {",
              "    console.log(\"❌ ALERTA DE INTEGRIDAD: El registro aún es consultable tras el DELETE.\");",
              "}"
