    {
      "name": "Delete Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar el Status Code (201 en Restful-Booker para Delete)",
              "pm.test(\"Status 201 - Registro eliminado correctamente\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 2. Validar que la respuesta sea un texto simple (Confirmación)",
              "pm.test(\"Confirmación de borrado: Respuesta es 'Created'\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"Created\");",
              "});",
              "",
              "// 3. Script Pro: Limpiar las gavetas (Variables)",
              "// Al borrar el registro, la variable ya no es útil. La limpiamos para no causar errores luego.",
              "pm.environment.unset(\"last_booking_id\");",
              "console.log(\"♻️ Variable 'last_booking_id' eliminada del entorno.\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
